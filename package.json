{
  "name": "mission-control-backend",
  "version": "0.1.0",
  "private": true,
  "description": "My Mission Control — backend API (Express + Prisma + JWT)",
  "main": "src/index.js",
  "scripts": {
    "start": "prisma db push --accept-data-loss --skip-generate && node prisma/seed.js && node src/index.js",
    "dev": "node --watch src/index.js",
    "seed": "node prisma/seed.js",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "@anthropic-ai/sdk": "^0.40.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
