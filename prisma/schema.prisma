generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Profile {
  ADULT
  CHILD
}

enum Realm {
  FAMILY
  WORK
}

enum ImprovNature {
  MIXTE
  COMPAREE
}

enum ImprovDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ModuleStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum LessonKind {
  QUEST
  BOSS
  FREE
  CEREMONY
}

enum ProgressStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                         Int                       @id @default(autoincrement())
  email                      String                    @unique
  username                   String?                   @unique
  firstName                  String
  password                   String
  role                       Role                      @default(MEMBER)
  profile                    Profile                   @default(ADULT)
  mustChangePassword         Boolean                   @default(false)
  avatarData                 String?                   @db.Text   // data:image/webp;base64,... (Phase 3)
  avatarUpdatedAt            DateTime?
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  apps                       UserApp[]
  modules                    ModuleAccess[]
  progress                   Progress[]
  badges                     UserBadge[]
  improvSessions             ImprovSession[]
  kazChatSessions            KazChatSession[]
  pushSubscriptions          PushSubscription[]
  messagerieParticipations   ConversationParticipant[]
  messagerieMessages         Message[]
  fridayConversations        FridayConversation[]
}

model App {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String?
  url         String?
  icon        String
  color       String
  isActive    Boolean   @default(true)
  isMockup    Boolean   @default(true)
  realm       Realm     @default(FAMILY)
  createdAt   DateTime  @default(now())
  users       UserApp[]
}

model UserApp {
  id        Int      @id @default(autoincrement())
  userId    Int
  appId     Int
  hasAccess Boolean  @default(true)
  grantedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
}

// ============ ÉDUCATIF — architecture modulaire =============

model Module {
  id          Int            @id @default(autoincrement())
  slug        String         @unique
  title       String
  subtitle    String?
  description String?
  coverColor  String?
  coverIcon   String?
  version     String         @default("1.0.0")
  language    String         @default("fr-CA")
  avatarKey   String?
  status      ModuleStatus   @default(ACTIVE)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lessons     Lesson[]
  accesses   ModuleAccess[]
}

model ModuleAccess {
  id         Int      @id @default(autoincrement())
  userId     Int
  moduleId   Int
  hasAccess  Boolean  @default(true)
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Lesson {
  id         Int        @id @default(autoincrement())
  moduleId   Int
  slug       String
  chapter    Int        @default(1)
  order      Int        @default(0)
  kind       LessonKind @default(QUEST)
  title      String
  subtitle   String?
  conceptKey String?
  data       Json
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  module     Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progresses Progress[]

  @@unique([moduleId, slug])
  @@index([moduleId, chapter, order])
}

model Progress {
  id            Int             @id @default(autoincrement())
  userId        Int
  lessonId      Int
  status        ProgressStatus  @default(LOCKED)
  stars         Int             @default(0)
  hintsUsed     Int             @default(0)
  attempts      Int             @default(0)
  xpEarned      Int             @default(0)
  savedCode     String?
  firstDoneAt   DateTime?
  lastPlayedAt  DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson        Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Badge {
  id       Int         @id @default(autoincrement())
  slug     String      @unique
  title    String
  icon     String
  criteria Json
  users    UserBadge[]
}

model UserBadge {
  id       Int      @id @default(autoincrement())
  userId   Int
  badgeId  Int
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ============ IMPRO ENGINE =============

model ImprovCategory {
  id                 Int              @id @default(autoincrement())
  slug               String           @unique
  name               String
  shortDescription   String?
  rulesDescription   String?
  allowedNatures     ImprovNature[]
  minPlayers         Int              @default(1)
  maxPlayers         Int              @default(6)
  minDurationSec     Int              @default(60)
  maxDurationSec     Int              @default(300)
  defaultDurationSec Int              @default(180)
  caucusAllowed      Boolean          @default(true)
  defaultCaucusSec   Int              @default(20)
  themeRequired      Boolean          @default(true)
  constraintsAllowed Boolean          @default(true)
  difficulty         ImprovDifficulty @default(MEDIUM)
  practiceCompatible Boolean          @default(true)
  gameCompatible     Boolean          @default(true)
  tags               String[]         @default([])
  active             Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  themes             ImprovTheme[]
}

model ImprovTheme {
  id         Int              @id @default(autoincrement())
  slug       String           @unique
  name       String
  categoryId Int?
  category   ImprovCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  difficulty ImprovDifficulty @default(MEDIUM)
  tags       String[]         @default([])
  active     Boolean          @default(true)
  createdAt  DateTime         @default(now())
}

model ImprovConstraint {
  id          Int              @id @default(autoincrement())
  slug        String           @unique
  name        String
  description String?
  difficulty  ImprovDifficulty @default(MEDIUM)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
}

model ImprovSession {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode      String
  createdAt DateTime        @default(now())
  rounds    ImprovRound[]

  @@index([userId])
}

model ImprovRound {
  id         Int           @id @default(autoincrement())
  sessionId  Int
  session    ImprovSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orderIndex Int           @default(0)
  cardData   Json
  voteResult String?
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime      @default(now())

  @@index([sessionId, orderIndex])
}

// ============ KAZ CHAT (live tutor) =============

model KazChatSession {
  id         Int              @id @default(autoincrement())
  userId     Int
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonSlug String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  messages   KazChatMessage[]

  @@unique([userId, lessonSlug])
  @@index([userId])
}

model KazChatMessage {
  id        Int            @id @default(autoincrement())
  sessionId Int
  session   KazChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String         @db.Text
  actIndex  Int?
  createdAt DateTime       @default(now())

  @@index([sessionId, createdAt])
}

// ============ PUSH NOTIFICATIONS (Web Push + futur Expo) =============

model PushSubscription {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String    @unique
  p256dh      String?
  auth        String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())

  @@index([userId])
}

// ============ FRIDAY (Hermes home agent bridge) =============
// Pont chat entre Mission Control et l'agent Hermes domestique de Martin.
// Phase 1 : Martin only (admin). Phase 2 : kids restreints via FRIDAY policy.

model FridayConversation {
  id            Int             @id @default(autoincrement())
  userId        Int
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String          @default("Nouvelle conversation")
  pinned        Boolean         @default(false)
  archivedAt    DateTime?
  lastMessageAt DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  messages      FridayMessage[]

  @@index([userId, archivedAt, lastMessageAt])
}

model FridayMessage {
  id             Int                @id @default(autoincrement())
  conversationId Int
  conversation   FridayConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String             // "user" | "assistant" | "system"
  content        String             @db.Text
  metadata       Json?              // raw FRIDAY response, tool calls, sources, etc.
  errorMessage   String?            @db.Text
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
}

// File d'attente pull-mode : messages user en attente d'être consommés par FRIDAY.
// FRIDAY long-polls /api/friday/poll, claim un pending, traite, POST sa réponse à
// /api/friday/webhook avec pendingId. Une fois respondedAt set, le pending est
// archivé (mais on le garde pour debug / replay).
model FridayPendingMessage {
  id             Int       @id @default(autoincrement())
  userId         Int
  conversationId Int
  payload        Json      // user, conversation, message, history, context — ce que FRIDAY reçoit
  claimedAt      DateTime?
  respondedAt    DateTime?
  errorMessage   String?   @db.Text
  createdAt      DateTime  @default(now())

  @@index([claimedAt, respondedAt, createdAt])
}

// ============ MESSAGERIE FAMILIALE =============

model Conversation {
  id             Int                       @id @default(autoincrement())
  slug           String?                   @unique
  title          String?
  createdById    Int?
  createdAt      DateTime                  @default(now())
  lastMessageAt  DateTime                  @default(now())
  participants   ConversationParticipant[]
  messages       Message[]

  @@index([lastMessageAt])
}

model ConversationParticipant {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId       Int
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  imageData      String?      @db.Text    // data:image/webp;base64,... (Phase 3 image attachments)
  imageWidth     Int?
  imageHeight    Int?
  createdAt      DateTime     @default(now())
  editedAt       DateTime?

  @@index([conversationId, createdAt])
}
