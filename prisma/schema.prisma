generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum Profile {
  ADULT
  CHILD
}

enum Realm {
  FAMILY
  WORK
}

enum ImprovNature {
  MIXTE
  COMPAREE
}

enum ImprovDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ModuleStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum LessonKind {
  QUEST
  BOSS
  FREE
  CEREMONY
}

enum ProgressStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

model User {
  id                  Int            @id @default(autoincrement())
  email               String         @unique
  username            String?        @unique
  firstName           String
  password            String
  role                Role           @default(MEMBER)
  profile             Profile        @default(ADULT)
  mustChangePassword  Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  apps                UserApp[]
  modules             ModuleAccess[]
  progress            Progress[]
  badges              UserBadge[]
  improvSessions      ImprovSession[]
}

model App {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  name        String
  description String?
  icon        String
  color       String
  isActive    Boolean   @default(true)
  isMockup    Boolean   @default(true)
  realm       Realm     @default(FAMILY)
  createdAt   DateTime  @default(now())
  users       UserApp[]
}

model UserApp {
  id        Int      @id @default(autoincrement())
  userId    Int
  appId     Int
  hasAccess Boolean  @default(true)
  grantedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
}

// ============ ÉDUCATIF — architecture modulaire =============

// Un module = un pack pédagogique installé (ex: Code Cadet · Minecraft Protocol)
model Module {
  id          Int            @id @default(autoincrement())
  slug        String         @unique
  title       String
  subtitle    String?
  description String?
  coverColor  String?
  coverIcon   String?
  version     String         @default("1.0.0")
  language    String         @default("fr-CA")
  avatarKey   String?         // identifiant de la persona avatar (ex: rex-commandant)
  status      ModuleStatus   @default(ACTIVE)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  lessons     Lesson[]
  accesses   ModuleAccess[]
}

// Accès granulaire : qui peut voir/jouer ce module
model ModuleAccess {
  id         Int      @id @default(autoincrement())
  userId     Int
  moduleId   Int
  hasAccess  Boolean  @default(true)
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module     Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

// Une mission (quest) dans un chapitre d'un module
model Lesson {
  id         Int        @id @default(autoincrement())
  moduleId   Int
  slug       String
  chapter    Int        @default(1)
  order      Int        @default(0)
  kind       LessonKind @default(QUEST)
  title      String
  subtitle   String?
  conceptKey String?                              // ex: "sequence", "loop", "condition"
  data       Json                                 // tout le contenu (briefing, world, toolbox, success, hints)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  module     Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progresses Progress[]

  @@unique([moduleId, slug])
  @@index([moduleId, chapter, order])
}

// Progression par utilisateur par leçon
model Progress {
  id            Int             @id @default(autoincrement())
  userId        Int
  lessonId      Int
  status        ProgressStatus  @default(LOCKED)
  stars         Int             @default(0)
  hintsUsed     Int             @default(0)
  attempts      Int             @default(0)
  xpEarned      Int             @default(0)
  savedCode     String?                           // Blockly XML / JSON en cours
  firstDoneAt   DateTime?
  lastPlayedAt  DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson        Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Badge {
  id       Int         @id @default(autoincrement())
  slug     String      @unique
  title    String
  icon     String
  criteria Json
  users    UserBadge[]
}

model UserBadge {
  id       Int      @id @default(autoincrement())
  userId   Int
  badgeId  Int
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ============ IMPRO ENGINE =============

model ImprovCategory {
  id                 Int              @id @default(autoincrement())
  slug               String           @unique
  name               String
  shortDescription   String?
  rulesDescription   String?
  allowedNatures     ImprovNature[]
  minPlayers         Int              @default(1)
  maxPlayers         Int              @default(6)
  minDurationSec     Int              @default(60)
  maxDurationSec     Int              @default(300)
  defaultDurationSec Int              @default(180)
  caucusAllowed      Boolean          @default(true)
  defaultCaucusSec   Int              @default(20)
  themeRequired      Boolean          @default(true)
  constraintsAllowed Boolean          @default(true)
  difficulty         ImprovDifficulty @default(MEDIUM)
  practiceCompatible Boolean          @default(true)
  gameCompatible     Boolean          @default(true)
  tags               String[]         @default([])
  active             Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  themes             ImprovTheme[]
}

model ImprovTheme {
  id         Int              @id @default(autoincrement())
  slug       String           @unique
  name       String
  categoryId Int?
  category   ImprovCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  difficulty ImprovDifficulty @default(MEDIUM)
  tags       String[]         @default([])
  active     Boolean          @default(true)
  createdAt  DateTime         @default(now())
}

model ImprovConstraint {
  id          Int              @id @default(autoincrement())
  slug        String           @unique
  name        String
  description String?
  difficulty  ImprovDifficulty @default(MEDIUM)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
}

model ImprovSession {
  id        Int             @id @default(autoincrement())
  userId    Int
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode      String          // "PRACTICE" | "GAME"
  createdAt DateTime        @default(now())
  rounds    ImprovRound[]

  @@index([userId])
}

model ImprovRound {
  id         Int           @id @default(autoincrement())
  sessionId  Int
  session    ImprovSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orderIndex Int           @default(0)
  cardData   Json          // nature, category slug, theme slug, constraints, duration, caucus, players
  voteResult String?       // "A" | "B" | "TIE" | null (practice)
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime      @default(now())

  @@index([sessionId, orderIndex])
}
